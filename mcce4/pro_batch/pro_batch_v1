# Attempt to import MCCE4 benchmark resources if available
CLONE = Path(__file__).parent.parent
if CLONE.name != "MCCE4-Alpha":
    try:
        from mcce4.mcce_benchmark import BenchResources, datasets_dict
        inputpath_help = ("Path to a directory containing PDB files, or name of a pkdb dataset, "
